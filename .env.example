# Upstash Redis — free tier (10k commands/day), no card required.
# Create a database at https://console.upstash.com → copy the REST URL + token.
# The site runs fine WITHOUT these (counters read 0 and nothing is recorded),
# so local dev needs no setup.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Any random string. Vercel sends it as `Authorization: Bearer <CRON_SECRET>`
# when invoking the daily snapshot cron. Generate one: `openssl rand -hex 24`
CRON_SECRET=

# Public origin used in the "Copy install" curl command. Optional locally.
NEXT_PUBLIC_SITE_URL=https://skills.ai
